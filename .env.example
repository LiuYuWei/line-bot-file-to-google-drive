# LINE Bot Settings
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Google Drive Settings
# The ID of the folder where files will be uploaded (the string after /folders/ in URL)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Google Auth JSON string (obtained from Part 3 of README using get_token.py)
# Format: {"client_id": "...", "client_secret": "...", "refresh_token": "...", "type": "authorized_user"}
GOOGLE_SERVICE_ACCOUNT_JSON='{"client_id": "YOUR_ID", "client_secret": "YOUR_SECRET", "refresh_token": "YOUR_TOKEN", "type": "authorized_user"}'
